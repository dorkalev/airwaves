{
  "hosting": {
    "site": "airwaves-dorkalev",
    "public": "public",
    "cleanUrls": true,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(html|js|mjs)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
      }
    ]
  }
}
